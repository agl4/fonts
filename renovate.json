{
    "customManagers": [
        {
            "customType": "regex",
            "description": "Update _VERSION variables in Dockerfiles",
            "fileMatch": ["*?\\.mk"],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>[a-z-]+?)(?: depName=(?<depName>.+?))? packageName=(?<packageName>.+?)(?: versioning=(?<versioning>[a-z-]+?))(?: registryurl=(?<registryurl>[a-z-]+?))?\\s.+?_VERSION := (?<currentValue>.+?)\\s"
            ]
        }
    ]
}
